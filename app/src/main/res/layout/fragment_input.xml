<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <EditText
        android:id="@+id/lgli_et_income"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="შემოსავალი"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/lgli_et_expenses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="ხარჯები"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/lgli_et_income" />

    <Button
        android:id="@+id/lgli_btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="შენახვა"
        app:layout_constraintTop_toBottomOf="@id/lgli_et_expenses" />

</androidx.constraintlayout.widget.ConstraintLayout>